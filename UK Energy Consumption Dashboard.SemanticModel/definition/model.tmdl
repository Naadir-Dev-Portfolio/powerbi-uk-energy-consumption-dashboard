model Model
	culture: en-GB
	defaultPowerBIDataSourceVersion: powerBI_V3
	discourageImplicitMeasures
	sourceQueryCulture: en-GB
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_ProTooling = ["DevMode"]

annotation PBI_QueryOrder = ["Dim Date","Dim Geography","Dim Fuel","Dim Sector","Dim Electricity Profile","Fact Energy Consumption","Fact Electricity Profile","Latest Snapshot"]

ref table 'Dim Date'
ref table 'Dim Geography'
ref table 'Dim Fuel'
ref table 'Dim Sector'
ref table 'Dim Electricity Profile'
ref table 'Fact Energy Consumption'
ref table 'Fact Electricity Profile'
ref table 'Latest Snapshot'

ref cultureInfo en-GB

