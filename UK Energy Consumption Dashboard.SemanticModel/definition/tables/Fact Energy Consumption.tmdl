table 'Fact Energy Consumption'
	lineageTag: 16ffc0fe-7b5e-4462-aa8b-04815918d3db

	measure 'Consumption GWh' =
			VAR HasSingleSector = HASONEVALUE('Dim Sector'[Sector])
			RETURN
			    IF(
			        HasSingleSector,
			        SUM('Fact Energy Consumption'[ConsumptionGWh]),
			        CALCULATE(
			            SUM('Fact Energy Consumption'[ConsumptionGWh]),
			            KEEPFILTERS('Dim Sector'[CountsInAdditiveTotal] = TRUE())
			        )
			    )
		formatString: #,##0.0
		lineageTag: 5ba42449-42af-45b8-8e5e-9296b0412291

	measure 'Consumption TWh' = DIVIDE([Consumption GWh], 1000)
		formatString: #,##0.0
		lineageTag: 21a22536-0260-4a69-be78-ace510a76ef9

	measure 'Meter Count' =
			VAR HasSingleSector = HASONEVALUE('Dim Sector'[Sector])
			RETURN
			    IF(
			        HasSingleSector,
			        SUM('Fact Energy Consumption'[Meters]),
			        CALCULATE(
			            SUM('Fact Energy Consumption'[Meters]),
			            KEEPFILTERS('Dim Sector'[CountsInAdditiveTotal] = TRUE())
			        )
			    )
		formatString: #,##0
		lineageTag: a66741bb-2f54-4ac8-aa4b-8ab67e05dc06

	measure 'Mean kWh per meter' = DIVIDE([Consumption GWh] * 1000000, [Meter Count])
		formatString: #,##0
		lineageTag: 22b618e2-a962-42c9-9c62-e3c272b3d9b0

	measure 'Source Median kWh per meter' = AVERAGE('Fact Energy Consumption'[MedianKWhPerMeter])
		formatString: #,##0
		lineageTag: 9419e443-35a7-4f5f-8fa8-2f8b19e33bd9

	measure 'Domestic Consumption GWh' = CALCULATE([Consumption GWh], 'Dim Sector'[Sector] = "Domestic")
		formatString: #,##0.0
		lineageTag: 439d7729-77b7-4f48-a2d6-a4d795d12744

	measure 'Non-domestic Consumption GWh' = CALCULATE([Consumption GWh], 'Dim Sector'[Sector] = "Non-domestic")
		formatString: #,##0.0
		lineageTag: 11d44b53-7ea2-4875-a3e0-0e3511f51f76

	measure 'Domestic Mix Share' = DIVIDE([Domestic Consumption GWh], [Domestic Consumption GWh] + [Non-domestic Consumption GWh])
		formatString: 0.0%
		lineageTag: f94c0a6c-d19a-4bcb-9e43-daec01b6868d

	measure 'Non-domestic Mix Share' = DIVIDE([Non-domestic Consumption GWh], [Domestic Consumption GWh] + [Non-domestic Consumption GWh])
		formatString: 0.0%
		lineageTag: 855be925-04c9-4ed6-8152-84fe8793b8d8

	measure 'Electricity Consumption GWh' = CALCULATE([Consumption GWh], 'Dim Fuel'[Fuel] = "Electricity")
		formatString: #,##0.0
		lineageTag: 8325b2f6-cf87-48c4-ada7-7b7c06d0de6a

	measure 'Gas Consumption GWh' = CALCULATE([Consumption GWh], 'Dim Fuel'[Fuel] = "Gas")
		formatString: #,##0.0
		lineageTag: f75b6311-207e-41d6-aab1-9fbfac9606c0

	measure 'Electricity Share' = DIVIDE([Electricity Consumption GWh], [Electricity Consumption GWh] + [Gas Consumption GWh])
		formatString: 0.0%
		lineageTag: 22a45965-d9c9-404b-b68b-3c4c70d9a4b2

	measure 'Gas Share' = DIVIDE([Gas Consumption GWh], [Electricity Consumption GWh] + [Gas Consumption GWh])
		formatString: 0.0%
		lineageTag: 365aa9bf-7738-4b5d-8bb8-7f07cf5a0b01

	measure 'Latest Year' = CALCULATE(MAX('Dim Date'[YearKey]), REMOVEFILTERS('Dim Date'))
		formatString: 0
		lineageTag: 2faabfd7-073b-40f9-8b5a-5801fb34a380

	measure 'Latest Consumption GWh' =
			VAR LatestYear = [Latest Year]
			RETURN
			    CALCULATE(
			        [Consumption GWh],
			        REMOVEFILTERS('Dim Date'),
			        'Dim Date'[YearKey] = LatestYear
			    )
		formatString: #,##0.0
		lineageTag: f53e2bc1-366d-4576-8fd6-9cfb59924dbc

	measure 'Previous Year Consumption GWh' =
			VAR LatestYear = [Latest Year]
			RETURN
			    CALCULATE(
			        [Consumption GWh],
			        REMOVEFILTERS('Dim Date'),
			        'Dim Date'[YearKey] = LatestYear - 1
			    )
		formatString: #,##0.0
		lineageTag: 9ad6d150-b5a8-4963-9053-b6c075129fbf

	measure 'Latest YoY Change %' = DIVIDE([Latest Consumption GWh] - [Previous Year Consumption GWh], [Previous Year Consumption GWh])
		formatString: +0.0%;-0.0%;0.0%
		lineageTag: 62b734b1-e876-4392-b76f-00098012315d

	measure '2021 Baseline Consumption GWh' =
			CALCULATE(
			    [Consumption GWh],
			    REMOVEFILTERS('Dim Date'),
			    'Dim Date'[YearKey] = 2021
			)
		formatString: #,##0.0
		lineageTag: 9f83dc50-7566-4ac6-b0aa-b36fb60d5bab

	measure 'Latest vs 2021 Change %' = DIVIDE([Latest Consumption GWh] - [2021 Baseline Consumption GWh], [2021 Baseline Consumption GWh])
		formatString: +0.0%;-0.0%;0.0%
		lineageTag: c01210bb-8ca2-4030-9d30-410798a2bca3

	measure 'Latest Mean kWh per meter' =
			VAR LatestYear = [Latest Year]
			RETURN
			    CALCULATE(
			        [Mean kWh per meter],
			        REMOVEFILTERS('Dim Date'),
			        'Dim Date'[YearKey] = LatestYear
			    )
		formatString: #,##0
		lineageTag: 7cb92662-9cd7-49d1-8664-d0441832c69a

	measure '2021 Mean kWh per meter' =
			CALCULATE(
			    [Mean kWh per meter],
			    REMOVEFILTERS('Dim Date'),
			    'Dim Date'[YearKey] = 2021
			)
		formatString: #,##0
		lineageTag: a1a1e6d5-ee12-4f38-9838-51076f71db6d

	measure 'Mean Use Change since 2021 %' = DIVIDE([Latest Mean kWh per meter] - [2021 Mean kWh per meter], [2021 Mean kWh per meter])
		formatString: +0.0%;-0.0%;0.0%
		lineageTag: ef7544ca-41f9-46b6-8784-7356a52f81a3

	measure 'Ten Year Ago Consumption GWh' =
			VAR LatestYear = [Latest Year]
			RETURN
			    CALCULATE(
			        [Consumption GWh],
			        REMOVEFILTERS('Dim Date'),
			        'Dim Date'[YearKey] = LatestYear - 10
			    )
		formatString: #,##0.0
		lineageTag: 994226cc-1723-4f49-ad80-ce02f19eae27

	measure 'Ten Year CAGR' =
			VAR LatestValue = [Latest Consumption GWh]
			VAR PriorValue = [Ten Year Ago Consumption GWh]
			RETURN
			    IF(
			        NOT ISBLANK(LatestValue) && NOT ISBLANK(PriorValue) && PriorValue > 0,
			        POWER(DIVIDE(LatestValue, PriorValue), 0.1) - 1
			    )
		formatString: +0.0%;-0.0%;0.0%
		lineageTag: 33e9379d-2552-4029-9432-0838a1f5690e

	measure 'Local Authority Demand Rank' =
			VAR LatestYear = [Latest Year]
			RETURN
			    IF(
			        ISINSCOPE('Dim Geography'[GeographyName]),
			        RANKX(
			            FILTER(
			                ALLSELECTED('Dim Geography'[GeographyKey], 'Dim Geography'[GeographyName], 'Dim Geography'[GeographyLevel]),
			                'Dim Geography'[GeographyLevel] = "Local authority"
			            ),
			            CALCULATE(
			                [Consumption GWh],
			                REMOVEFILTERS('Dim Date'),
			                'Dim Date'[YearKey] = LatestYear
			            ),
			            ,
			            DESC,
			            Dense
			        )
			    )
		formatString: 0
		lineageTag: 7f07c26b-54e4-422c-a1e4-e53c1a7c4f17

	measure 'Demand Direction' =
			VAR YoY = [Latest YoY Change %]
			RETURN
			    SWITCH(
			        TRUE(),
			        ISBLANK(YoY), "No comparison",
			        YoY >= 0.03, "Rising",
			        YoY <= -0.03, "Falling",
			        "Stable"
			    )
		lineageTag: d16c105e-3ac5-49ac-9bc0-4858771cf831

	measure 'Structural Change Signal' =
			VAR YoY = [Latest YoY Change %]
			VAR Since2021 = [Latest vs 2021 Change %]
			RETURN
			    SWITCH(
			        TRUE(),
			        ISBLANK(YoY) || ISBLANK(Since2021), "Insufficient history",
			        Since2021 <= -0.10 && ABS(YoY) <= 0.03, "Lower plateau after 2021",
			        Since2021 <= -0.10 && YoY > 0.03, "Partial rebound from lower base",
			        Since2021 < -0.03, "Lower than 2021",
			        YoY >= 0.05, "Short-term pressure rising",
			        YoY <= -0.05, "Recent demand easing",
			        "Broadly stable"
			    )
		lineageTag: ebc5fe1d-00b4-4dea-96e6-44a3c98a2baa

	measure 'Efficiency Signal' =
			VAR MeanChange = [Mean Use Change since 2021 %]
			RETURN
			    SWITCH(
			        TRUE(),
			        ISBLANK(MeanChange), "No comparison",
			        MeanChange <= -0.10, "Large reduction in mean use",
			        MeanChange <= -0.03, "Moderate reduction in mean use",
			        MeanChange >= 0.03, "Mean use rising",
			        "Mean use stable"
			    )
		lineageTag: fea3615b-baf5-4c2c-8ad8-927ef1efcb64

	measure 'Executive Takeaway' =
			"Latest demand is " & LOWER([Demand Direction]) &
			"; consumption is " & FORMAT([Latest vs 2021 Change %], "+0.0%;-0.0%;0.0%") &
			" versus 2021 and mean use per meter is " &
			FORMAT([Mean Use Change since 2021 %], "+0.0%;-0.0%;0.0%") &
			" versus 2021."
		lineageTag: ba3443fc-2c2f-4ed4-8abb-c360b6dd73e3

	measure 'Three Year Rolling Avg GWh' =
			VAR CurrentYear = MAX('Dim Date'[YearKey])
			VAR WindowYears =
			    FILTER(
			        ALL('Dim Date'),
			        'Dim Date'[YearKey] <= CurrentYear &&
			        'Dim Date'[YearKey] > CurrentYear - 3
			    )
			RETURN
			    AVERAGEX(WindowYears, CALCULATE([Consumption GWh]))
		formatString: #,##0.0
		displayFolder: Trend Analysis
		lineageTag: 5ffc57b8-57ad-42dd-b3c7-bab17cad5e7e

