	measure 'Filtered Local Authorities' =
			CALCULATE(
			    DISTINCTCOUNT('Fact Energy Consumption'[GeographyKey]),
			    KEEPFILTERS('Dim Geography'[GeographyLevel] = "Local authority")
			)
		formatString: #,##0
		displayFolder: Explorer
		lineageTag: 12add536-74fa-4f52-8883-88605fe38213

	measure 'Top Region Label' =
			VAR Regions =
			    FILTER(
			        ALLSELECTED('Dim Geography'[RegionName]),
			        NOT ISBLANK('Dim Geography'[RegionName])
			    )
			VAR TopRegion =
			    TOPN(
			        1,
			        Regions,
			        CALCULATE(
			            [Latest Consumption GWh],
			            KEEPFILTERS('Dim Geography'[GeographyLevel] = "Local authority")
			        ),
			        DESC,
			        'Dim Geography'[RegionName], ASC
			)
			RETURN
			    MAXX(TopRegion, 'Dim Geography'[RegionName])
		displayFolder: Labels
		lineageTag: bf2481ff-6a71-4d5f-b562-a511c9e256bd

	measure 'Top Region Latest GWh' =
			VAR Regions =
			    FILTER(
			        ALLSELECTED('Dim Geography'[RegionName]),
			        NOT ISBLANK('Dim Geography'[RegionName])
			    )
			VAR TopRegion =
			    TOPN(
			        1,
			        Regions,
			        CALCULATE(
			            [Latest Consumption GWh],
			            KEEPFILTERS('Dim Geography'[GeographyLevel] = "Local authority")
			        ),
			        DESC,
			        'Dim Geography'[RegionName], ASC
			    )
			RETURN
			    MAXX(
			        TopRegion,
			        CALCULATE(
			            [Latest Consumption GWh],
			            KEEPFILTERS('Dim Geography'[GeographyLevel] = "Local authority")
			        )
			    )
		formatString: #,##0.0
		displayFolder: Labels
		lineageTag: 4b94b5b5-c31f-4842-b527-9a7cc01f4efc

	measure 'Top Local Authority Label' =
			VAR Candidates =
			    SUMMARIZE(
			        FILTER(
