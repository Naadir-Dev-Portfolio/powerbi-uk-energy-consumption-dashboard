	partition 'Fact Energy Consumption' = m
		mode: import
		source =
				let
					Source = Csv.Document(File.Contents(ProcessedDataFolder & "\fact_energy_consumption.csv"), [Delimiter=",", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),
					Headers = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),
					Typed = Table.TransformColumnTypes(Headers, {
						{"YearKey", Int64.Type},
						{"GeographyKey", type text},
						{"Fuel", type text},
						{"Sector", type text},
						{"MetersThousands", type number},
						{"Meters", type number},
						{"ConsumptionGWh", type number},
						{"ConsumptionKWh", type number},
						{"MeanKWhPerMeter", type number},
						{"MedianKWhPerMeter", type number},
						{"SourceGranularity", type text}
					}, "en-GB")
				in
					Typed

