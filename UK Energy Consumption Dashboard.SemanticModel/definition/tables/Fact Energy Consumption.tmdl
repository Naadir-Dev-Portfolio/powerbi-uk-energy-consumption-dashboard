	measure 'Latest Snapshot Label' = FORMAT([Latest Snapshot Date], "yyyy")
		displayFolder: Latest Snapshot
		lineageTag: 8aa5d7ce-4f53-4134-9657-9070f56f20bb

	measure 'Latest vs 2021 GWh' = [Latest Consumption GWh] - [2021 Baseline Consumption GWh]
		formatString: +#,##0.0;-#,##0.0;0.0
		displayFolder: Latest Snapshot
		lineageTag: 84e52253-e62b-4df3-86c4-c53ae7bf4cfb

	measure 'Great Britain Latest vs 2021 GWh' =
			CALCULATE(
			    [Latest vs 2021 GWh],
			    REMOVEFILTERS('Dim Geography'),
			    'Dim Geography'[GeographyCode] = "K03000001",
			    'Dim Geography'[GeographyLevel] = "Great Britain"
			)
		formatString: +#,##0.0;-#,##0.0;0.0
		displayFolder: Great Britain
		lineageTag: 2c439ca2-6db3-4f3f-bc4f-f2671fe53e8d

	measure 'Great Britain Latest Domestic Consumption GWh' =
			CALCULATE(
			    [Latest Consumption GWh],
			    REMOVEFILTERS('Dim Geography'),
			    'Dim Geography'[GeographyCode] = "K03000001",
			    'Dim Geography'[GeographyLevel] = "Great Britain",
			    REMOVEFILTERS('Dim Sector'),
			    'Dim Sector'[Sector] = "Domestic"
			)
		formatString: #,##0.0
		displayFolder: Great Britain
		lineageTag: 53ed7c9f-f2a3-43cd-87ec-8169f9ad8c84

	measure 'Great Britain Latest Non-domestic Consumption GWh' =
			CALCULATE(
			    [Latest Consumption GWh],
			    REMOVEFILTERS('Dim Geography'),
			    'Dim Geography'[GeographyCode] = "K03000001",
			    'Dim Geography'[GeographyLevel] = "Great Britain",
			    REMOVEFILTERS('Dim Sector'),
			    'Dim Sector'[Sector] = "Non-domestic"
			)
		formatString: #,##0.0
		displayFolder: Great Britain
		lineageTag: 923c110f-87c4-4289-9db5-402807c5799d

	measure 'Great Britain Electricity Share' = DIVIDE([Great Britain Electricity Consumption GWh], [Great Britain Electricity Consumption GWh] + [Great Britain Gas Consumption GWh])
		formatString: 0.0%
		displayFolder: Great Britain
		lineageTag: 8d3d3172-865d-4858-a419-dff9081fcd53

	measure 'Great Britain Gas Share' = DIVIDE([Great Britain Gas Consumption GWh], [Great Britain Electricity Consumption GWh] + [Great Britain Gas Consumption GWh])
		formatString: 0.0%
		displayFolder: Great Britain
		lineageTag: 13f1fd1c-61a4-4c85-98b2-9637507510cb

	measure 'Great Britain Latest Electricity Share %' =
			DIVIDE(
			    [Great Britain Latest Electricity Consumption GWh],
			    [Great Britain Latest Electricity Consumption GWh] + [Great Britain Latest Gas Consumption GWh]
			)
		formatString: 0.0%
		displayFolder: Great Britain
		lineageTag: 7a4a2374-90cc-4724-82fb-5b9d7c03bda4

	measure 'Great Britain Latest Gas Share %' =
			DIVIDE(
			    [Great Britain Latest Gas Consumption GWh],
			    [Great Britain Latest Electricity Consumption GWh] + [Great Britain Latest Gas Consumption GWh]
			)
		formatString: 0.0%
		displayFolder: Great Britain
		lineageTag: d28d3ef2-970d-43bc-8d81-df950a7d0375

