		annotation UnderlyingDateTimeDataType = Date

	column YearLabel
		dataType: string
		lineageTag: 982e30f7-c055-4786-9917-f5d585d61825
		summarizeBy: none
		sourceColumn: YearLabel
		sortByColumn: YearSort

	column YearSort
		dataType: int64
		lineageTag: 946f7012-8f57-4735-96fa-f1be0ea5a0c6
