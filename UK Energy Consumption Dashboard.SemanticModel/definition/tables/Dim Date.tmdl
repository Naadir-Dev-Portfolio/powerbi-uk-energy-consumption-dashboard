table 'Dim Date'
	lineageTag: 966ca163-0be0-4df9-895f-2d9ddfb6c621

	column YearKey
		dataType: int64
		isKey
		lineageTag: ccd25bd9-1558-419f-af91-b649c8b88240
		summarizeBy: none
		sourceColumn: YearKey

	column YearStartDate
		dataType: dateTime
		formatString: yyyy
