	partition 'Dim Date' = m
		mode: import
		source =
				let
					Source = Csv.Document(File.Contents(ProcessedDataFolder & "\dim_date.csv"), [Delimiter=",", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),
					Headers = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),
					Typed = Table.TransformColumnTypes(Headers, {
						{"YearKey", Int64.Type},
						{"YearStartDate", type date},
						{"YearLabel", type text},
						{"YearSort", Int64.Type},
						{"PeriodGroup", type text},
						{"IsLatestYear", type logical},
						{"YearsSinceStart", Int64.Type}
					}, "en-GB")
				in
					Typed

